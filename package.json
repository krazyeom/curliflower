{
  "name": "curliflower",
  "version": "1.0.0",
  "main": "main.js",
  "description": "Premium multi-request automation tool for fetch and curl.",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --mac",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac",
    "android:prepare": "mkdir -p www && cp index.html style.css renderer.js bridge.js logo.png guide.png www/",
    "android:sync": "npx cap sync",
    "android:build": "npm run android:prepare && npm run android:sync",
    "android:open": "npx cap open android",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "krazyeom",
  "build": {
    "appId": "com.krazyeom.curliflower",
    "productName": "Curliflower",
    "files": [
      "**/*",
      ".env"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "logo.png"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "logo.png"
    }
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/preferences": "^8.0.1",
    "@supabase/supabase-js": "^2.104.1",
    "auto-launch": "^5.0.6",
    "axios": "^1.15.2",
    "electron-store": "^8.1.0",
    "node-machine-id": "^1.1.12",
    "parse-curl": "^0.2.6"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  }
}
